@{
    Layout = "_Layout";
}
<h2>Admin Dashboard</h2>
<div class="row">
    <div class="col-md-4">
        <div class="card bg-primary text-white p-3">
            <h3>Total Users: @ViewBag.UserCount</h3>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white p-3">
            <h3>Total Weight Logs: @ViewBag.TotalLogs</h3>
        </div>
    </div>
</div>