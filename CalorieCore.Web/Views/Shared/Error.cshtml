@model CalorieCore.ViewModels.ErrorViewModel
@{
    ViewData["Title"] = "System Error";
}

<div class="container mt-5 pt-5 text-center">
    <div class="glass-card p-5 mx-auto" style="max-width: 700px; border-bottom: 4px solid #ffc107;">
        <h1 class="display-1 fw-bold gradient-text">500</h1>
        <h2 class="mb-4 text-white">Something went wrong in the kitchen...</h2>

        <p class="text-light mb-4">
            Our servers are having a bit of trouble processing that request.
            The chef has been notified and we're looking into it!
        </p>

        @if (Model.ShowRequestId)
        {
            <div class="alert alert-dark bg-dark text-secondary border-0 small mb-5">
                <strong>Error Reference:</strong> <code>@Model.RequestId</code>
            </div>
        }

        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Home" asp-action="Index" class="btn btn-warning fw-bold px-4">
                <i class="bi bi-house-door me-2"></i>Home
            </a>
            <button onclick="location.reload()" class="btn btn-outline-light-custom px-4">
                <i class="bi bi-arrow-clockwise me-2"></i>Try Again
            </button>
        </div>
    </div>
</div>

<style>
    code {
        color: #ffc107;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
    }
</style>