@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5 pt-5 text-center">
    <div class="glass-card p-5 mx-auto" style="max-width: 600px; border-top: 4px solid #dc3545;">
        <h1 class="display-1 fw-bold text-danger"><i class="bi bi-shield-lock"></i></h1>
        <h2 class="mb-4 text-white">Access Denied</h2>
        <p class="text-light mb-5">
            You don't have permission to view or edit this kitchen's secrets.
            Only the owner of this recipe can make changes.
        </p>
        <a asp-controller="Recipes" asp-action="Index" class="btn btn-outline-light-custom px-4">
            Return to Recipes
        </a>
    </div>
</div>