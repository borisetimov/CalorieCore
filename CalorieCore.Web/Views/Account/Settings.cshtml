@model CalorieCore.ViewModels.SettingsViewModel

<div class="container py-5">
    <div class="d-flex align-items-center mb-5">
        <div class="position-relative me-4">
            <div class="p-1 rounded-circle" style="background: linear-gradient(45deg, #ffca28, #ff8f00);">
                <img src="https://ui-avatars.com/api/?name=@Model.Username&background=212529&color=ffca28&size=80"
                     class="rounded-circle border border-3 border-dark" alt="Profile">
            </div>
        </div>
        <div>
            <h2 class="gradient-text fw-bold mb-0">Settings</h2>
            <p class="text-secondary small mb-0">Manage your physical profile and account security</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success bg-success bg-opacity-10 border-success text-success small py-2 mb-4 animate__animated animate__fadeIn">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="glass-card p-4 border border-secondary border-opacity-25 h-100">
                <h5 class="text-white fw-bold mb-4 d-flex align-items-center">
                    <i class="bi bi-person-gear text-warning me-2"></i> Physical Profile
                </h5>

                <form asp-action="UpdateProfile" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="setting-input-box p-3 rounded-3 bg-dark bg-opacity-50 border border-secondary border-opacity-10">
                                <label class="text-secondary tiny-label">HEIGHT (CM)</label>
                                <div class="d-flex align-items-center mt-1">
                                    <i class="bi bi-rulers text-warning me-3 opacity-75"></i>
                                    <input type="number" asp-for="Height" step="0.1"
                                           class="form-control bg-transparent border-0 text-white fw-bold p-0 shadow-none" />
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="setting-input-box p-3 rounded-3 bg-dark bg-opacity-50 border border-secondary border-opacity-10">
                                <label class="text-secondary tiny-label">GENDER</label>
                                <div class="d-flex align-items-center mt-1">
                                    <i class="bi bi-gender-ambiguous text-info me-3 opacity-75"></i>
                                    <select asp-for="Gender" class="form-select bg-transparent border-0 text-white fw-bold p-0 shadow-none">
                                        <option value="Male" class="bg-dark text-white">Male</option>
                                        <option value="Female" class="bg-dark text-white">Female</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="setting-input-box p-3 rounded-3 bg-dark bg-opacity-50 border border-secondary border-opacity-10">
                                <label class="text-secondary tiny-label">AGE</label>
                                <div class="d-flex align-items-center mt-1">
                                    <i class="bi bi-calendar-event text-warning me-3 opacity-75"></i>
                                    <input type="number" asp-for="Age"
                                           class="form-control bg-transparent border-0 text-white fw-bold p-0 shadow-none" />
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="setting-input-box p-3 rounded-3 bg-dark bg-opacity-50 border border-secondary border-opacity-10">
                                <label class="text-secondary tiny-label">ACTIVITY LEVEL</label>
                                <div class="d-flex align-items-center mt-1">
                                    <i class="bi bi-lightning-charge text-warning me-3 opacity-75"></i>
                                    <select asp-for="ActivityLevel" class="form-select bg-transparent border-0 text-white fw-bold p-0 shadow-none">
                                        <option value="Sedentary" class="bg-dark text-white">Sedentary</option>
                                        <option value="Lightly Active" class="bg-dark text-white">Lightly Active</option>
                                        <option value="Moderately Active" class="bg-dark text-white">Moderately Active</option>
                                        <option value="Very Active" class="bg-dark text-white">Very Active</option>
                                        <option value="Extra Active" class="bg-dark text-white">Extra Active</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-warning fw-bold px-4 py-2 mt-3 shadow-sm hover-grow">
                        Save Changes
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="d-flex flex-column gap-4">

                <div class="glass-card p-4 border border-secondary border-opacity-25">
                    <h5 class="text-white fw-bold mb-3 small opacity-75">ACCOUNT INFO</h5>

                    <div class="mb-3 d-flex justify-content-between align-items-center">
                        <span class="text-secondary small">Username</span>
                        <span class="text-white fw-bold">@Model.Username</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-secondary small">Email</span>
                        <span class="text-white small">@Model.Email</span>
                    </div>
                </div>

                <div class="glass-card p-4 border border-danger border-opacity-10 bg-danger bg-opacity-10">
                    <h6 class="text-danger fw-bold mb-2">Danger Zone</h6>
                    <p class="text-secondary mb-3" style="font-size: 0.75rem;">Permanent account deletion.</p>

                    <form asp-action="DeleteAccount" method="post" onsubmit="return confirm('Confirm permanent deletion?');">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                            Delete Account
                        </button>
                    </form>
                </div>

                <a asp-controller="Home" asp-action="Index" class="text-secondary text-center text-decoration-none small mt-2">
                    <i class="bi bi-arrow-left me-1"></i> Dashboard
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .gradient-text {
        background: linear-gradient(45deg, #fff, #ffca28);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .tiny-label {
        font-size: 0.6rem;
        font-weight: 800;
        letter-spacing: 1.2px;
        display: block;
    }

    .setting-input-box {
        transition: all 0.2s ease;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
    }

        .setting-input-box:focus-within {
            background-color: rgba(0, 0, 0, 0.6) !important;
            border-color: rgba(255, 202, 40, 0.3) !important;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

    .hover-grow {
        transition: transform 0.2s;
    }

        .hover-grow:hover {
            transform: translateY(-2px);
        }

    /* Remove arrows from number input */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
</style>