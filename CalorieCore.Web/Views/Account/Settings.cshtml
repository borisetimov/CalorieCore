@model CalorieCore.ViewModels.SettingsViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="glass-card p-5 shadow-lg text-center border border-secondary border-opacity-25">

                @* Profile Header *@
                <div class="position-relative mb-4">
                    <div class="d-inline-block p-1 rounded-circle bg-gradient-warning" style="background: linear-gradient(45deg, #ffca28, #ff8f00);">
                        <img src="https://ui-avatars.com/api/?name=@Model.Username&background=212529&color=ffca28&size=128"
                             class="rounded-circle border border-3 border-dark"
                             alt="Profile">
                    </div>
                    <h2 class="gradient-text fw-bold mt-3 mb-0">Account Settings</h2>
                    <p class="text-secondary small">Manage your profile and preferences</p>
                </div>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success bg-success bg-opacity-10 border-success text-success small py-2 mb-4">
                        @TempData["Success"]
                    </div>
                }

                <hr class="border-secondary opacity-25 my-4">

                @* Editable Profile Form *@
                <form asp-action="UpdateProfile" method="post" class="text-start mb-4">
                    @Html.AntiForgeryToken()

                    @* Height Input *@
                    <div class="mb-3 p-3 rounded-3 bg-dark bg-opacity-50 border border-secondary border-opacity-10 profile-input-group">
                        <label class="text-secondary small fw-bold text-uppercase d-block mb-1" style="font-size: 0.65rem; letter-spacing: 1px;">Height (cm)</label>
                        <div class="d-flex align-items-center">
                            <div class="bg-warning bg-opacity-10 p-2 rounded-3 me-3">
                                <i class="bi bi-rulers text-warning fs-5"></i>
                            </div>
                            <input type="number" asp-for="Height" step="0.1"
                                   class="form-control bg-transparent border-0 text-white fw-bold p-0 shadow-none"
                                   placeholder="Enter height..." />
                        </div>
                    </div>

                    @* Gender Select *@
                    <div class="mb-4 p-3 rounded-3 bg-dark bg-opacity-50 border border-secondary border-opacity-10 profile-input-group">
                        <label class="text-secondary small fw-bold text-uppercase d-block mb-1" style="font-size: 0.65rem; letter-spacing: 1px;">Gender</label>
                        <div class="d-flex align-items-center">
                            <div class="bg-info bg-opacity-10 p-2 rounded-3 me-3">
                                <i class="bi bi-gender-ambiguous text-info fs-5"></i>
                            </div>
                            <select asp-for="Gender" class="form-select bg-transparent border-0 text-white fw-bold p-0 shadow-none" style="cursor: pointer;">
                                <option value="Male" class="bg-dark text-white">Male</option>
                                <option value="Female" class="bg-dark text-white">Female</option>
                            </select>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-warning w-100 fw-bold py-2 mb-4 shadow-sm">
                        <i class="bi bi-check2-circle me-2"></i> Save Changes
                    </button>
                </form>

                @* Read-Only Account Info *@
                <div class="text-start mb-5">
                    <div class="d-flex align-items-center mb-3 p-3 rounded-3 bg-dark bg-opacity-25 border border-secondary border-opacity-10">
                        <div class="bg-secondary bg-opacity-10 p-2 rounded-3 me-3">
                            <i class="bi bi-person-circle text-secondary fs-4"></i>
                        </div>
                        <div>
                            <label class="text-secondary small fw-bold text-uppercase d-block" style="font-size: 0.65rem; letter-spacing: 1px;">Username</label>
                            <span class="text-white fw-bold">@Model.Username</span>
                        </div>
                    </div>

                    <div class="d-flex align-items-center p-3 rounded-3 bg-dark bg-opacity-25 border border-secondary border-opacity-10">
                        <div class="bg-secondary bg-opacity-10 p-2 rounded-3 me-3">
                            <i class="bi bi-envelope-at text-secondary fs-4"></i>
                        </div>
                        <div>
                            <label class="text-secondary small fw-bold text-uppercase d-block" style="font-size: 0.65rem; letter-spacing: 1px;">Email Address</label>
                            <span class="text-white">@Model.Email</span>
                        </div>
                    </div>
                </div>

                @* Danger Zone *@
                <div class="p-4 rounded-4 border border-danger border-opacity-25 bg-danger bg-opacity-10">
                    <h5 class="text-danger fw-bold mb-2 small text-uppercase" style="letter-spacing: 1px;">Danger Zone</h5>
                    <p class="text-secondary small mb-3">Deleting your account is permanent and cannot be undone.</p>

                    <form asp-action="DeleteAccount" method="post" onsubmit="return confirm('WARNING: Are you sure you want to delete your account? All data will be lost forever.');">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-danger w-100 fw-bold py-2">
                            <i class="bi bi-trash3 me-2"></i> Delete Account
                        </button>
                    </form>
                </div>

                <div class="mt-4">
                    <a asp-controller="Home" asp-action="Index" class="text-secondary text-decoration-none small">
                        <i class="bi bi-arrow-left"></i> Back to Dashboard
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    .gradient-text {
        background: linear-gradient(45deg, #fff, #ffca28);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .profile-input-group {
        transition: all 0.2s ease;
    }

        .profile-input-group:focus-within {
            background-color: rgba(0, 0, 0, 0.7) !important;
            transform: scale(1.02);
            border-color: rgba(255, 202, 40, 0.4) !important;
            box-shadow: 0 0 15px rgba(255, 202, 40, 0.1);
        }

    /* Clean up number input arrows */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
</style>