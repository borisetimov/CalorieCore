@model IEnumerable<CalorieCore.DataModels.WeightLog>

@{
    ViewData["Title"] = "Weight Progress";
    // Prepare data for Javascript
    var labels = Model.Select(m => m.DateRecorded.ToString("MMM dd")).ToList();
    var values = Model.Select(m => m.Weight).ToList();
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="glass-card p-4 mb-4">
                <h3 class="text-white mb-3">Update Weight</h3>
                <form asp-action="LogWeight" method="post">
                    <div class="mb-3">
                        <label class="text-light">Current Weight (kg)</label>
                        <input type="number" step="0.1" name="weight" class="form-control bg-dark text-white border-secondary" required />
                    </div>
                    <button type="submit" class="btn btn-warning w-100 fw-bold">Save Log</button>
                </form>
            </div>
        </div>

        <div class="col-md-8">
            <div class="glass-card p-4">
                <h3 class="text-white mb-3">Progress Chart</h3>
                <canvas id="weightChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('weightChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(labels)),
                datasets: [{
                    label: 'Weight (kg)',
                    data: @Html.Raw(Json.Serialize(values)),
                    borderColor: '#ffc107',
                    backgroundColor: 'rgba(255, 193, 7, 0.2)',
                    borderWidth: 3,
                    tension: 0.4, 
                    fill: true
                }]
            },
            options: {
                plugins: { legend: { labels: { color: 'white' } } },
                scales: {
                    y: { ticks: { color: 'rgba(255,255,255,0.7)' }, grid: { color: 'rgba(255,255,255,0.1)' } },
                    x: { ticks: { color: 'rgba(255,255,255,0.7)' }, grid: { display: false } }
                }
            }
        });
    </script>
}