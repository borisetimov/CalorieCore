@model CalorieCore.Web.ViewModels.WeightViewModel

@{
    ViewData["Title"] = "Weight Progress";

    // 1. Data Preparation for Chart
    var chartLogs = Model.Logs.OrderBy(l => l.DateRecorded).ToList();
    var labels = chartLogs.Select(m => m.DateRecorded.ToString("dd MMM")).ToList();
    var values = chartLogs.Select(m => m.Weight).ToList();

    var startingWeight = chartLogs.FirstOrDefault()?.Weight ?? 0;
    var weightChange = Model.CurrentWeight - startingWeight;

    // 2. Dynamic Gauge Calculations
    double gaugeMin = 10;
    double gaugeMax = 50;
    double totalRange = gaugeMax - gaugeMin;

    double blueStop = ((18.5 - gaugeMin) / totalRange) * 50;
    double greenStop = ((25.0 - gaugeMin) / totalRange) * 50;
    double yellowStop = ((30.0 - gaugeMin) / totalRange) * 50;
}

<div class="container mt-4">
    <div class="row mb-4">
        @* Modern BMI Gauge Section *@
        <div class="col-md-8">
            <div class="glass-card p-4 h-100 text-center">
                <h4 class="text-white mb-4 text-start"><i class="bi bi-speedometer2 me-2"></i>Body Mass Index (BMI)</h4>

                @if (Model.Status != null)
                {
                    <div class="gauge-container mx-auto">
                        <div class="gauge-ring-modern"
                             style="background: conic-gradient(from 270deg,
                                                    #5bc0de 0% @(blueStop)%,
                                                    #5cb85c @(blueStop)% @(greenStop)%,
                                                    #f0ad4e @(greenStop)% @(yellowStop)%,
                                                    #d9534f @(yellowStop)% 50%,
                                                    #1a1a1a 50% 100%);">

                            <div class="needle" id="bmiPointer"></div>

                            <div class="gauge-center-info">
                                <h1 class="display-3 fw-bold text-white mb-0">@Model.Status.BMI</h1>
                                <span class="badge rounded-pill bg-@Model.Status.Color.ToLower() px-3 py-2 text-uppercase">
                                    @Model.Status.Category
                                </span>
                            </div>
                        </div>
                    </div>

                    @* Healthy Norm Info & Advice Message *@
                    <div class="mt-4 pt-2 border-top border-secondary border-opacity-25">
                        <p class="text-light mb-1">
                            Based on your height (@Model.Height cm), the healthy norm is:
                        </p>
                        <h5 class="text-success fw-bold">@Model.Status.MinNormalWeight kg - @Model.Status.MaxNormalWeight kg</h5>

                        @* The Message from your WeightCalculator.cs *@
                        <div class="mt-3 p-2 rounded bg-dark bg-opacity-50 border border-info border-opacity-25">
                            <p class="text-info m-0 small italic">
                                <i class="bi bi-chat-left-dots me-2"></i>@Model.Status.Message
                            </p>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* Compact Stats & Body Fat Column *@
        <div class="col-md-4">
            <div class="d-flex flex-column gap-3 h-100">
                <div class="d-flex gap-2">
                    <div class="glass-card p-2 flex-grow-1 text-center">
                        <h6 class="text-secondary small mb-1" style="font-size: 0.7rem;">CURRENT WEIGHT</h6>
                        <h4 class="text-warning m-0">@Model.CurrentWeight<span class="small" style="font-size: 0.6em;">kg</span></h4>
                    </div>
                    <div class="glass-card p-2 flex-grow-1 text-center">
                        <h6 class="text-secondary small mb-1" style="font-size: 0.7rem;">TOTAL CHANGE</h6>
                        <h4 class="@(weightChange <= 0 ? "text-success" : "text-danger") m-0">
                            @(weightChange > 0 ? "+" : "")@weightChange.ToString("0.0")<span class="small" style="font-size: 0.6em;">kg</span>
                        </h4>
                    </div>
                </div>

                @* Body Fat Calculator Card *@
                <div class="glass-card p-3 flex-grow-1">
                    <h6 class="text-white mb-3"><i class="bi bi-percent me-2"></i>Body Fat Calculator</h6>

                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <label class="text-secondary small">Age (Years)</label>
                            <input type="number" id="bfAge" class="form-control form-control-sm bg-dark text-white border-secondary" placeholder="Age">
                        </div>
                        <div class="col-6">
                            <label class="text-secondary small">Gender</label>
                            <select id="bfGender" class="form-select form-select-sm bg-dark text-white border-secondary" onchange="toggleHipField()">
                                <option value="male">Male</option>
                                <option value="female">Female</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <label class="text-secondary small">Waist (cm)</label>
                            <input type="number" id="bfWaist" class="form-control form-control-sm bg-dark text-white border-secondary" placeholder="cm">
                        </div>
                        <div class="col-6">
                            <label class="text-secondary small">Neck (cm)</label>
                            <input type="number" id="bfNeck" class="form-control form-control-sm bg-dark text-white border-secondary" placeholder="cm">
                        </div>
                    </div>

                    @* Hips input - hidden by default, shown for females *@
                    <div id="hipContainer" class="mb-3 d-none">
                        <label class="text-secondary small">Hips (cm)</label>
                        <input type="number" id="bfHips" class="form-control form-control-sm bg-dark text-white border-secondary" placeholder="cm">
                    </div>

                    <button type="button" class="btn btn-warning btn-sm w-100 fw-bold mb-3 shadow-sm" onclick="calculateBF()">
                        Calculate Body Fat
                    </button>

                    <div class="row g-2">
                        <div class="col-6">
                            <div class="text-center p-2 rounded bg-black bg-opacity-25 border border-secondary border-opacity-25">
                                <span class="text-secondary d-block" style="font-size: 0.6rem;">NAVY METHOD</span>
                                <h4 id="bfResultNavy" class="text-info m-0" style="font-size: 1.1rem;">--%</h4>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="text-center p-2 rounded bg-black bg-opacity-25 border border-secondary border-opacity-25">
                                <span class="text-secondary d-block" style="font-size: 0.6rem;">BMI METHOD</span>
                                <h4 id="bfResultBMI" class="text-warning m-0" style="font-size: 1.1rem;">--%</h4>
                            </div>
                        </div>
                    </div>
                    <div class="text-center mt-2">
                        <span id="bfCategory" class="text-secondary small text-uppercase" style="font-size: 0.65rem;">Result Status</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Trend & History Rows *@
    <div class="row">
        <div class="col-md-4">
            <div class="glass-card p-4 mb-4">
                <h4 class="text-white mb-3"><i class="bi bi-plus-circle me-2"></i>New Entry</h4>
                <form asp-action="LogWeight" asp-controller="Weight" method="post">
                    <div class="mb-3">
                        <label class="text-light small">Weight (kg)</label>
                        <input type="number" step="0.1" name="weight" class="form-control bg-dark text-white border-secondary" placeholder="@Model.CurrentWeight" required />
                    </div>
                    <button type="submit" class="btn btn-warning w-100 fw-bold">Update Progress</button>
                </form>
            </div>

            <div class="glass-card p-0 overflow-hidden">
                <div class="p-3 border-bottom border-secondary">
                    <h5 class="text-white m-0">Recent History</h5>
                </div>
                <div style="max-height: 300px; overflow-y: auto;">
                    <table class="table table-dark table-hover m-0">
                        <tbody>
                            @foreach (var log in Model.Logs.OrderByDescending(l => l.DateRecorded))
                            {
                                <tr>
                                    <td class="ps-3 align-middle">@log.DateRecorded.ToString("dd MMM")</td>
                                    <td class="fw-bold text-warning align-middle text-center">@log.Weight kg</td>
                                    <td class="text-end pe-3">
                                        <button type="button" class="btn btn-link text-danger p-0 border-0" onclick="openDeleteModal(@log.Id)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="glass-card p-4 h-100">
                <h4 class="text-white mb-4"><i class="bi bi-graph-up me-2"></i>Weight Trend</h4>
                <div style="height: 350px; position: relative;">
                    <canvas id="weightChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_DeleteModal" />

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Gauge Pointer Logic
            const bmiVal = parseFloat("@Model.Status?.BMI".replace(',', '.'));
            const pointer = document.getElementById("bmiPointer");
            if (pointer && !isNaN(bmiVal)) {
                const minB = 10;
                const maxB = 50;
                let percent = (bmiVal - minB) / (maxB - minB);
                percent = Math.max(0, Math.min(1, percent));
                const angle = -90 + (percent * 180);
                pointer.style.transform = `translateX(-50%) rotate(${angle}deg)`;
            }

            // Chart Logic
            const ctx = document.getElementById('weightChart');
            if (ctx) {
                new Chart(ctx.getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: @Html.Raw(Json.Serialize(labels)),
                        datasets: [{
                            label: 'Weight (kg)',
                            data: @Html.Raw(Json.Serialize(values)),
                            borderColor: '#ffc107',
                            backgroundColor: 'rgba(255, 193, 7, 0.1)',
                            borderWidth: 3,
                            tension: 0.3,
                            fill: true,
                            pointRadius: 5,
                            pointBackgroundColor: '#ffc107'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { ticks: { color: '#aaa' }, grid: { color: 'rgba(255,255,255,0.05)' } },
                            x: { ticks: { color: '#aaa' }, grid: { display: false } }
                        }
                    }
                });
            }
        });

        function toggleHipField() {
            const gender = document.getElementById("bfGender").value;
            const hipContainer = document.getElementById("hipContainer");
            if (gender === "female") {
                hipContainer.classList.remove("d-none");
            } else {
                hipContainer.classList.add("d-none");
            }
        }

        // BODY FAT CALCULATION (U.S. NAVY METRIC + BMI METHODS)
        function calculateBF() {
            const age = parseInt(document.getElementById("bfAge").value);
            const waist = parseFloat(document.getElementById("bfWaist").value);
            const neck = parseFloat(document.getElementById("bfNeck").value);
            const hips = parseFloat(document.getElementById("bfHips").value);
            const gender = document.getElementById("bfGender").value;

            const weight = parseFloat("@Model.CurrentWeight".replace(',', '.'));
            const heightCm = parseFloat("@Model.Height".replace(',', '.'));

            if (!age || !waist || !neck || !weight || !heightCm || (gender === "female" && isNaN(hips))) {
                alert("Please fill in all measurements. (Hips required for women)");
                return;
            }

            // 1. BMI CALCULATION
            const heightM = heightCm / 100;
            const bmi = weight / (heightM * heightM);

            // 2. BMI METHOD FORMULAS (Standardized)
            let bmiResult = 0;
            if (age >= 18) {
                bmiResult = (gender === "male")
                    ? (1.20 * bmi) + (0.23 * age) - 16.2
                    : (1.20 * bmi) + (0.23 * age) - 5.4;
            } else {
                bmiResult = (gender === "male")
                    ? (1.51 * bmi) - (0.70 * age) - 2.2
                    : (1.51 * bmi) - (0.70 * age) + 1.4;
            }

            // 3. UPDATED NAVY METHOD FORMULAS (Metric Units)
            let navyResult = 0;
            if (gender === "male") {
                // BFP = 495 / (1.0324 - 0.19077 * log10(waist - neck) + 0.15456 * log10(height)) - 450
                let density = 1.0324 - (0.19077 * Math.log10(waist - neck)) + (0.15456 * Math.log10(heightCm));
                navyResult = (495 / density) - 450;
            } else {
                // BFP = 495 / (1.29579 - 0.35004 * log10(waist + hip - neck) + 0.22100 * log10(height)) - 450
                let density = 1.29579 - (0.35004 * Math.log10(waist + hips - neck)) + (0.22100 * Math.log10(heightCm));
                navyResult = (495 / density) - 450;
            }

            // Update UI
            document.getElementById("bfResultNavy").innerText = Math.max(2, navyResult).toFixed(1) + "%";
            document.getElementById("bfResultBMI").innerText = Math.max(2, bmiResult).toFixed(1) + "%";

            // Categorization
            let cat = "Average";
            if (gender === "male") {
                if (bmiResult < 14) cat = "Athletes";
                else if (bmiResult > 25) cat = "Obese";
            } else {
                if (bmiResult < 21) cat = "Athletes";
                else if (bmiResult > 32) cat = "Obese";
            }
            document.getElementById("bfCategory").innerText = cat;
        }

        function openDeleteModal(id) {
            const form = document.getElementById('deleteForm');
            if (form) {
                form.action = '/Weight/DeleteLog/' + id;
                new bootstrap.Modal(document.getElementById('deleteModal')).show();
            }
        }
    </script>
}