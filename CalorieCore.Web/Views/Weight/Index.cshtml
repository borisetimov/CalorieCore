@model IEnumerable<CalorieCore.DataModels.WeightLog>

@{
    ViewData["Title"] = "Weight Progress";
    var labels = Model.Select(m => m.DateRecorded.ToString("MMM dd")).ToList();
    var values = Model.Select(m => m.Weight).ToList();

    var currentWeight = Model.LastOrDefault()?.Weight ?? 0;
    var startingWeight = Model.FirstOrDefault()?.Weight ?? 0;
    var weightChange = currentWeight - startingWeight;
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="glass-card p-3 text-center">
                <h6 class="text-secondary text-uppercase small">Starting</h6>
                <h2 class="text-white">@startingWeight <span class="small">kg</span></h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-card p-3 text-center border-start border-warning">
                <h6 class="text-secondary text-uppercase small">Current</h6>
                <h2 class="text-warning">@currentWeight <span class="small">kg</span></h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-card p-3 text-center">
                <h6 class="text-secondary text-uppercase small">Total Change</h6>
                <h2 class="@(weightChange <= 0 ? "text-success" : "text-danger")">
                    @(weightChange > 0 ? "+" : "")@weightChange.ToString("0.0") <span class="small">kg</span>
                </h2>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="glass-card p-4 mb-4">
                <h4 class="text-white mb-3"><i class="bi bi-plus-circle me-2"></i>New Entry</h4>
                <form asp-action="LogWeight" method="post">
                    <div class="mb-3">
                        <label class="text-light small">Weight (kg)</label>
                        <input type="number" step="0.1" name="weight" class="form-control bg-dark text-white border-secondary" placeholder="0.0" required />
                    </div>
                    <button type="submit" class="btn btn-warning w-100 fw-bold">Update Progress</button>
                </form>
            </div>

            <div class="glass-card p-0 overflow-hidden">
                <div class="p-3 border-bottom border-secondary">
                    <h5 class="text-white m-0">Recent Logs</h5>
                </div>
                <div style="max-height: 300px; overflow-y: auto;">
                    <table class="table table-dark table-hover m-0">
                        <thead class="small text-secondary">
                            <tr>
                                <th class="ps-3">Date</th>
                                <th>Weight</th>
                                <th class="text-end pe-3">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.OrderByDescending(x => x.DateRecorded))
                            {
                                <tr>
                                    <td class="ps-3 align-middle">@log.DateRecorded.ToString("dd MMM")</td>
                                    <td class="fw-bold text-warning align-middle">@log.Weight kg</td>
                                    <td class="text-end pe-3">
                                        <button type="button" class="btn btn-link text-danger p-0 border-0" onclick="openDeleteModal(@log.Id)">
                                            <i class="bi bi-trash3 small"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="glass-card p-4 h-100">
                <h4 class="text-white mb-4"><i class="bi bi-graph-up me-2"></i>Weight Trend</h4>
                <div style="height: 400px;">
                    <canvas id="weightChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_DeleteModal" />

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>

        const ctx = document.getElementById('weightChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(labels)),
                datasets: [{
                    label: 'Weight Progress',
                    data: @Html.Raw(Json.Serialize(values)),
                    borderColor: '#ffc107',
                    backgroundColor: 'rgba(255, 193, 7, 0.1)',
                    borderWidth: 4,
                    pointBackgroundColor: '#ffc107',
                    pointRadius: 5,
                    tension: 0.3,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        ticks: { color: '#aaa' },
                        grid: { color: 'rgba(255,255,255,0.05)' }
                    },
                    x: {
                        ticks: { color: '#aaa' },
                        grid: { display: false }
                    }
                }
            }
        });


        function openDeleteModal(id) {
            const form = document.getElementById('deleteForm');
            form.action = '/Weight/DeleteLog/' + id;
            const myModal = new bootstrap.Modal(document.getElementById('deleteModal'));
            myModal.show();
        }
    </script>
}